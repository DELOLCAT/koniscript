{
    "configurations":[
        {
          "name": "Debug Rust (CodeLLDB)",
          "type": "lldb",
          "request": "launch",
          "program": "${workspaceFolder}/kovm/target/debug/kovm",
          "args": [
            "run",
            "${workspaceFolder}/test.rvm"
          ],
          "cwd": "${workspaceFolder}",
          "sourceLanguages": ["rust"]
        },
        {
            "name": "Compiler",
            "type": "debugpy",
            "request": "launch",
            "program": "./src/koni_compiler/koni.py",
            "console": "integratedTerminal",
            "args": [
                "compile",
                "tmp/new.kn"
            ],
        },
    ]
}