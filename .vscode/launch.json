{
    "configurations":[
        {
          "name": "Debug Rust (CodeLLDB)",
          "type": "lldb",
          "request": "launch",
          "program": "${workspaceFolder}/lolscript_vm/target/debug/lolscript_vm",
          "args": [
            "run",
            "${workspaceFolder}/test.lsc"
          ],
          "cwd": "${workspaceFolder}",
          "sourceLanguages": ["rust"]
        },
        {
            "name": "both",
            "type": "debugpy",
            "request": "launch",
            "program": "lolscript.py",
            "console": "integratedTerminal",
            "args": ["run", "test.ls"]
        },
        {
            "name": "Compiler",
            "type": "debugpy",
            "request": "launch",
            "program": "./lolscript.py",
            "console": "integratedTerminal",
            "args": [
                "compile",
                "test.ls"
            ],
        },
        {
            "name": "VM",
            "type": "debugpy",
            "request": "launch",
            "program": "./VM.py",
            "args": [
                "./test.lsc"
            ]
        },
    ]
}