{
    "configurations":[
        {
          "name": "Debug Rust (CodeLLDB)",
          "type": "lldb",
          "request": "launch",
          "program": "${workspaceFolder}/ray_vm/target/debug/ray_vm",
          "args": [
            "run",
            "${workspaceFolder}/test.rvm"
          ],
          "cwd": "${workspaceFolder}",
          "sourceLanguages": ["rust"]
        },
        {
            "name": "both",
            "type": "debugpy",
            "request": "launch",
            "program": "ray.py",
            "console": "integratedTerminal",
            "args": ["run", "test.ray"]
        },
        {
            "name": "Compiler",
            "type": "debugpy",
            "request": "launch",
            "program": "./ray.py",
            "console": "integratedTerminal",
            "args": [
                "compile",
                "test.ray"
            ],
        },
        {
            "name": "VM",
            "type": "debugpy",
            "request": "launch",
            "program": "./VM.py",
            "args": [
                "./test.rvm"
            ]
        },
    ]
}