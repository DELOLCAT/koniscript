{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "koniscript",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#function_calls"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#dictionaries"
		},
		{
			"include": "#variables"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.koniscript",
					"match": "(?<!\\.)(\\b(if|while|func|return|else|or|and|not|import|break|let|continue|null|export)\\b|@require)"
				},
				{
					"name": "constant.character.koniscript",
					"match": "(?<!\\.)(\\b(true|false)\\b)"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.koniscript",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.koniscript",
							"match": "\\\\."
						}
					]
				},
				{
					"name": "string.quoted.single.koniscript",
					"begin": "'",
					"end": "'",
					"patterns": [
						{
							"name": "constant.character.escape.koniscript",
							"match": "\\\\."
						}
					]
				}
			]
		},
		"function_calls": {
			"name": "entity.name.function.koniscript",
			"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
		},
		"variables": {
			"name": "variable.other.koniscript",
			"match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
		},
		"numbers": {
			"name": "constant.numeric.koniscript",
			"match": "\\b[0-9]+(\\.[0-9]+)?\\b"
		},
		"operators": {
			"name": "keyword.operator.koniscript",
			"match": "[+\\-*/%=<>!&|]+"
		},
		"comments": {
			"name": "comment.line.koniscript",
			"begin": "#",
			"end": "$"
		},
		"dictionaries": {
			"name": "meta.dictionary.koniscript",
			"begin": "%\\{",
			"end": "\\}",
			"patterns": [
				{
					"include": "#comments"
				},
				{
					"include": "#keywords"
				},
				{
					"include": "#strings"
				},
				{
					"include": "#function_calls"
				},
				{
					"include": "#operators"
				},
				{
					"include": "#numbers"
				},
				{
					"include": "#variables"
				}
			]
		}
	},
	"scopeName": "source.koniscript"
}