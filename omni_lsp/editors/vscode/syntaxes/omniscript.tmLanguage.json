{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "OmniScript",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#function_calls"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#variables"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.omniscript",
					"match": "(?<!\\.)(\\b(if|while|func|return|else|or|and|not|import)\\b|@require)"
				},
				{
					"name": "constant.character.omniscript",
					"match": "(?<!\\.)(\\b(true|false)\\b)"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.omniscript",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.omniscript",
							"match": "\\\\."
						}
					]
				},
				{
					"name": "string.quoted.single.omniscript",
					"begin": "'",
					"end": "'",
					"patterns": [
						{
							"name": "constant.character.escape.omniscript",
							"match": "\\\\."
						}
					]
				}
			]
		},
		"function_calls": {
			"name": "entity.name.function.omniscript",
			"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
		},
		"variables": {
			"name": "variable.other.omniscript",
			"match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
		},
		"numbers": {
			"name": "constant.numeric.omniscript",
			"match": "\\b[0-9]+(\\.[0-9]+)?\\b"
		},
		"operators": {
			"name": "keyword.operator.omniscript",
			"match": "[+\\-*/%=<>!&|]+"
		},
		"comments": {
			"name": "comment.line.omniscript",
			"begin": "#",
			"end": "$"
		}
	},
	"scopeName": "source.omniscript"
}